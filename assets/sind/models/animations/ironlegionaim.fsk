{Head5_rotY} = -clamp((-{pitch}' * {data_1}), 0', 0')
{RightArm5_rotY} = -clamp((-{pitch}' * {data_1}), 0', 0')

{mk40_rotY} = clamp( ({yaw} - {bodyYaw})' * {data_1}, -12, 6)
