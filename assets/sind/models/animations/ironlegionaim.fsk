{data_0} = curve {data_0}
{data_1} = curve {data_1}

{RightArm2_rotX} @ {data_0} -> -pi / 2
{RightArm3_rotX} @ {data_0} -> -pi / 2
{RightArm4_rotX} @ {data_0} -> -pi / 2
{RightArm5_rotX} @ {data_0} -> -pi / 2
{RightArm6_rotX} @ {data_0} -> -pi / 2
{RightArm7_rotX} @ {data_0} -> -pi / 2

{fire2_posY} -= 11*{data_0}
{fire3_posY} -= 11*{data_0}
{fire4_posY} -= 11*{data_0}
{fire5_posY} -= 11*{data_0}
{fire6_posY} -= 11*{data_0}
{fire7_posY} -= 11*{data_0}

{mk15_rotY} = clamp( ({yaw} - {bodyYaw})' * {data_1}, -12, 6)
{Head2_rotX} += ({pitch}' * {data_1})
{Head2_rotY} = -clamp((-{pitch}' * {data_1}), 0', 0')
{RightArm2_rotY} = -clamp((-{pitch}' * {data_1}), 0', 0')

{mk33_rotY} = clamp( ({yaw} - {bodyYaw})' * {data_1}, -12, 6)
