{data_0} = curve {data_0}
{wobble2} = {data_0}sin(2pi{data_1})
{wobble4} = {data_0}sin(4pi{data_1})
{wobble2p05} = {data_0}sin(2pi{data_1} + pi / 2)

{Head2_rotX} -= 0.5'{wobble2}
{Head2_rotZ} -= 0.4'{wobble2p05}
{RightArm2_rotX} -= 1.5'{wobble4}{wobble2}
{LeftArm2_rotX} += 1.5'{wobble4}{wobble2p05}
{RightArm2_rotZ} += 4'{data_0} + 2'{wobble2}
{LeftArm2_rotZ} -= 4'{data_0} + 2'{wobble2}
{RightLeg2_rotX} += 2'{wobble4}{wobble2}
{LeftLeg2_rotX} -= 2'{wobble4}{wobble2p05}

{Head3_rotX} -= 0.5'{wobble2}
{Head3_rotZ} -= 0.4'{wobble2p05}
