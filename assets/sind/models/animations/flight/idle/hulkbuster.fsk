{data_0} = curve {data_0}
{wobble2} = {data_0}sin(2pi{data_1})
{wobble4} = {data_0}sin(4pi{data_1})
{wobble2p05} = {data_0}sin(2pi{data_1} + pi / 2)

{headBuster_rotX} -= 0.5'{wobble2}
{headBuster_rotZ} -= 0.4'{wobble2p05}

{rightArmBuster_rotX} -= 1.5'{wobble4}{wobble2}
{leftArmBuster_rotX} += 1.5'{wobble4}{wobble2p05}
{rightArmBuster_rotZ} += 4'{data_0} + 2'{wobble2}
{leftArmBuster_rotZ} -= 4'{data_0} + 2'{wobble2}

{rightLegBuster_rotX} += 2'{wobble4}{wobble2}
{leftLegBuster_rotX} -= 2'{wobble4}{wobble2p05}

out "pivot" (0, 0.7, 0)
out "rotate" (0.6{wobble2p05}, 0, 0, 1)
out "pivot" (0, 0.56, 0)
out "rotate" (0.6{wobble2}, 1, 0, 0)
