
{data} = curve {data}
{1} = curve min(2(animate2({data}, 0.2, 0, 0.1, 0.1), 1))
{2} = curve min(2(animate2({data}, 1, 0.1, 0.2, 0.2), 1))
{3} = curve min(2(animate2({data}, 1, 0.2, 0.2, 0.3), 1))
{4} = curve min(2(animate2({data}, 1, 0.4, 0.3, 0.2), 1))
