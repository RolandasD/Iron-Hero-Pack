{6} = curve min(2(animate2({data}, 1, 0.8, 0.3, 0.2), 1))

{1} *= 1 - {6}
{2} *= 1 - {6}
{3} *= 1 - {6}
{4} *= 1 - {6}
{5} *= 1 - {6}

